{
  "name": "alife-cloudflare",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "dev:api": "wrangler dev worker/index.js --local",
    "dev:full": "concurrently -n ui,api -c cyan,green \"npm run dev\" \"npm run dev:api\"",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy:api": "wrangler deploy worker/index.js"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^7.3.1"
  }
}
